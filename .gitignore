# Build outputs
Build/
dist/
*.o
*.obj
*.efi.unsigned
tools/abl-patcher/abl-patcher
tools/fv-unwrap/fv-unwrap
tests/*/test_*
!tests/*/test_*.c
!tests/*/test_*.h
!tests/*/test_*.sh

# Session/tooling state
.claude/
.omc/
tests/*/.omc/

# Stock OTA partition images — top-level only.
# (Anchored with a leading slash so `tests/images/` stays tracked: that's
# where committed ABL fixtures for the patch test harness live.)
/images/
!/images/.gitkeep
!/images/README.md

# Mode-2 profile payloads — gitignored; manifest.json is tracked (Plan 2)
profiles/*/profile.h
profiles/*/[!manifest]*.bin

# Device test logs
logs/

# RE staging (transient)
.re-notes-staging/

# Python
__pycache__/
*.pyc
.venv/

# Editor
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Recovery ZIP staging (populated by scripts/build-recovery-zip.sh)
zip/gbl-chainload/bin/
zip/gbl-chainload/base/
zip/gbl-chainload/SHA256SUMS
