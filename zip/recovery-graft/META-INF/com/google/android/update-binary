#!/sbin/sh
# recovery-graft installer. User-run from custom recovery only.

OUTFD="$2"
ZIPFILE="$3"

ui_print() {
  if [ -n "$OUTFD" ] && [ -e "/proc/self/fd/$OUTFD" ]; then
    echo "ui_print $1" > "/proc/self/fd/$OUTFD"
    echo "ui_print" > "/proc/self/fd/$OUTFD"
  else
    echo "$1"
  fi
}

abort() { ui_print "ERROR: $1"; exit 1; }
need_cmd() { command -v "$1" >/dev/null 2>&1 || abort "missing required recovery command: $1"; }

need_cmd awk
need_cmd dd
need_cmd mkdir
need_cmd sha256sum
need_cmd sync
need_cmd unzip

WORK=/tmp/recovery-graft-install
MANIFEST="$WORK/manifest"
IMAGE="$WORK/recovery-grafted.img"
rm -rf "$WORK"
mkdir -p "$WORK" || abort "failed to create work directory"

unzip -p "$ZIPFILE" payload/manifest > "$MANIFEST" || abort "failed to extract manifest"
unzip -p "$ZIPFILE" payload/recovery-grafted.img > "$IMAGE" || abort "failed to extract recovery image"

get_manifest() { awk -F= -v key="$1" '$1 == key { print $2; exit }' "$MANIFEST"; }
EXPECTED_SHA="$(get_manifest recovery_sha256)"
EXPECTED_SIZE="$(get_manifest recovery_size)"
ACTUAL_SHA="$(sha256sum "$IMAGE" | awk '{print $1}')"
ACTUAL_SIZE="$(wc -c < "$IMAGE" | tr -d ' ')"
[ "$ACTUAL_SHA" = "$EXPECTED_SHA" ] || abort "recovery payload hash mismatch"
[ "$ACTUAL_SIZE" = "$EXPECTED_SIZE" ] || abort "recovery payload size mismatch"

slot="$(getprop ro.boot.slot_suffix 2>/dev/null || true)"
if [ -z "$slot" ] && [ -r /proc/cmdline ]; then
  slot="$(tr ' ' '\n' < /proc/cmdline | awk -F= '$1 == "androidboot.slot_suffix" {print $2; exit}')"
fi

TARGET=""
if [ -n "$slot" ] && [ -e "/dev/block/by-name/recovery${slot}" ]; then
  TARGET="/dev/block/by-name/recovery${slot}"
elif [ -e /dev/block/by-name/recovery ]; then
  TARGET=/dev/block/by-name/recovery
elif [ -n "$slot" ] && [ -e "/dev/block/bootdevice/by-name/recovery${slot}" ]; then
  TARGET="/dev/block/bootdevice/by-name/recovery${slot}"
elif [ -e /dev/block/bootdevice/by-name/recovery ]; then
  TARGET=/dev/block/bootdevice/by-name/recovery
fi
[ -n "$TARGET" ] || abort "could not identify recovery block target"

if command -v blockdev >/dev/null 2>&1; then
  PART_SIZE="$(blockdev --getsize64 "$TARGET" 2>/dev/null || echo 0)"
  [ "$PART_SIZE" -eq 0 ] || [ "$ACTUAL_SIZE" -le "$PART_SIZE" ] || abort "recovery payload exceeds target partition"
fi

BACKUP="/sdcard/recovery-before-graft${slot}.img"
dd if="$TARGET" of="$BACKUP" bs=1048576 || abort "failed to back up current recovery"
dd if="$IMAGE" of="$TARGET" bs=1048576 conv=fsync || abort "failed to write grafted recovery"
sync
ui_print "Installed grafted recovery to $TARGET"
ui_print "Backup saved to $BACKUP"
exit 0
